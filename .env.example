# Configuración del Bot de Telegram
TELEGRAM_TOKEN=tu_token_del_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Token para proteger el endpoint /cron (generar uno aleatorio, p.ej. openssl rand -hex 32)
# Si está vacío, el endpoint /cron es público (no recomendado en producción)
CRON_TOKEN=
# IDs de tópicos del foro (0 = sin tópico, envío al chat general)
# News     → news_monitor (noticias económicas)
# Swing    → detectores 1D + 4H  (Gold y EUR/USD)
# Intraday → detectores 1H       (Gold y EUR/USD)
# Scalping → detectores 15M + 5M (Gold y EUR/USD)
THREAD_ID_NEWS=878
THREAD_ID_SWING=539
THREAD_ID_INTRADAY=537
THREAD_ID_SCALPING=535

# Configuración de Base de Datos Turso (SQLite Cloud)
# Obtén estos valores en: https://turso.tech/
TURSO_DATABASE_URL=libsql://tu-database-url.turso.io
TURSO_AUTH_TOKEN=tu_token_de_autenticacion_turso

# BD secundaria Turso — escrituras de alto volumen (ohlcv, logs, historial, api_key_usage)
# Opcional pero recomendado para no consumir el presupuesto de rows-written de la BD principal.
# Si no se define, las escrituras van a la BD principal.
TURSO_DATABASE_URL_2=libsql://tu-bd-secundaria.turso.io
TURSO_AUTH_TOKEN_2=tu_token_bd_secundaria

# ─────────────────────────────────────────────────────────────
# FUENTES DE DATOS — APIs opcionales para tiempo real
# ─────────────────────────────────────────────────────────────
# Twelve Data (GRATUITO — 800 req/día, sin tarjeta)
# Registro: https://twelvedata.com/apikey
# Necesario para datos en tiempo real en detectores 5M y 15M
TWELVE_DATA_API_KEY=tu_clave_twelve_data_aqui
TWELVE_DATA_API_KEY_2=tu_clave_twelve_data_cuenta2_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_3=tu_clave_twelve_data_cuenta3_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_4=tu_clave_twelve_data_cuenta4_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_5=tu_clave_twelve_data_cuenta5_aqui  # opcional, backup automático (800 req/día extra)

# ─────────────────────────────────────────────────────────────
# ALERTAS POR EMAIL — fallos de detectores
# ─────────────────────────────────────────────────────────────
# Servidor SMTP desde el que se envían los emails de alerta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Cuenta de Gmail que envía el correo (requiere "Contraseña de aplicación" si tienes 2FA)
SMTP_USER=
SMTP_PASSWORD=
# Destinatario de los emails de alerta (por defecto yesod3d@gmail.com)
ALERT_EMAIL=
DIRECT_FETCH_MODE=true

# ── Auto-cierre de señales activas ante eventos macro ─────────────────────────
# Opciones:
#   none         → nunca cerrar automáticamente (por defecto)
#   fomc         → cerrar solo en FOMC / Discurso Powell
#   high_impact  → cerrar en cualquier evento crítico (FOMC, NFP, CPI, PIB, PCE)
#   all          → cerrar en cualquier evento del calendario
AUTO_CLOSE_ON_EVENTS=none

# ─────────────────────────────────────────────────────────────
# MT5 / VT MARKETS — Ejecución automática de órdenes
# ─────────────────────────────────────────────────────────────
# Poner MT5_AUTO_TRADE=true para activar operaciones automáticas.
# Solo funciona en Windows con MetaTrader5 instalado localmente.
# En entornos Linux (Render) esta opción se ignora automáticamente.
MT5_AUTO_TRADE=false
# Número de cuenta demo VT Markets
MT5_LOGIN=
# Contraseña de la cuenta
MT5_PASSWORD=
# Nombre exacto del servidor MT5 (ver en MetaTrader5 → Herramientas → Opciones → Servidor)
MT5_SERVER=VTMarkets-Demo
# Símbolo tal como aparece en el Market Watch de MT5
MT5_SYMBOL=XAUUSD
# Lotes fijos por operación
MT5_LOTES=0.01

# ─── Puente Windows local (para ejecutar desde Render) ───────────────────────
# Si el bot corre en Render (Linux), usa este puente para llegar a MT5.
# 1. Ejecuta en tu PC: .venv\Scripts\python.exe bridge\mt5_bridge.py
# 2. Expón el puerto con ngrok: ngrok http 5001
# 3. Pega la URL ngrok aquí (cambia cada sesión en plan gratuito)
MT5_BRIDGE_URL=                # ej: https://xxxx.ngrok-free.app
MT5_BRIDGE_TOKEN=              # token secreto (cualquier string largo, lo mismo en el bridge)
MT5_BRIDGE_PORT=5001           # puerto del bridge local (solo si lo cambias)

# ─────────────────────────────────────────────────────────────
# CTRADER / PEPPERSTONE — Ejecución automática vía Open API
# ─────────────────────────────────────────────────────────────
# PASOS PARA CONFIGURAR:
#  1. Regístrate en Pepperstone y abre una cuenta demo cTrader
#  2. Ve a https://openapi.ctrader.com → crea una aplicación nueva
#  3. En el Playground de tu app, haz clic en "Get token" (scope: trading)
#  4. Copia el accessToken, refreshToken y el ctidTraderAccountId
#
# Compatible con Render (Linux): no requiere MT5 instalado localmente.
CTRADER_AUTO_TRADE=false
# Client ID y Client Secret de tu aplicación Open API (pestaña Credentials)
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Access token OAuth2 (obtenido desde el Playground, dura ~30 días)
CTRADER_ACCESS_TOKEN=
# Refresh token (para renovar el access token automáticamente)
CTRADER_REFRESH_TOKEN=
# ID numérico de la cuenta cTrader (ctidTraderAccountId, visible en el Playground)
CTRADER_ACCOUNT_ID=
# Símbolo tal como aparece en cTrader (puede variar: XAUUSD, XAUUSDm, etc.)
CTRADER_SYMBOL=XAUUSD
# Volumen en unidades cTrader (100 = aprox. 0.01 lote en XAUUSD Pepperstone)
CTRADER_VOLUME=100
# 'true' para cuenta demo, 'false' para cuenta live
CTRADER_DEMO=true

# ─────────────────────────────────────────────────────────────
# CTRADER FIX API — Ejecución automática vía protocolo FIX 4.4
# ─────────────────────────────────────────────────────────────
# Alternativa a la Open API WebSocket. Usa TCP/SSL directamente.
# Compatible con Render (Linux): no requiere MT5 instalado.
#
# PASOS PARA CONFIGURAR:
#  1. En cTrader Web → Mi cuenta → FIX API → copiar los datos de conexión
#  2. Rellenar las variables de abajo con esos datos
#  3. Poner FIX_AUTO_TRADE=true para activar operaciones reales
#
# Conexión de Operación (Trade) — puerto SSL 5212
# Conexión de Precios (Quote)  — puerto SSL 5211
FIX_AUTO_TRADE=false
# Hostname del servidor FIX (visible en la pantalla FIX API de cTrader)
FIX_HOST=demo-us-eqx-01.p.c-trader.com
# Puerto SSL para la sesión de precios (Quote)
FIX_QUOTE_PORT=5211
# Puerto SSL para la sesión de operaciones (Trade)
FIX_TRADE_PORT=5212
# SenderCompID (formato: demo.pepperstone.XXXXXXX)
FIX_SENDER_COMP=demo.pepperstone.5288500
# TargetCompID (siempre cServer en Pepperstone)
FIX_TARGET_COMP=cServer
# Número de cuenta (Username en el Logon FIX)
FIX_USERNAME=5288500
# Contraseña de la cuenta cTrader
FIX_PASSWORD=
# Símbolo a operar
FIX_SYMBOL=XAUUSD
# Lotes por operación (ej: 0.01)
FIX_LOTES=0.01
