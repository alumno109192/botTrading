# Configuración del Bot de Telegram
TELEGRAM_TOKEN=tu_token_del_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Token para proteger el endpoint /cron (generar uno aleatorio, p.ej. openssl rand -hex 32)
# Si está vacío, el endpoint /cron es público (no recomendado en producción)
CRON_TOKEN=
# IDs de tópicos del foro (0 = sin tópico, envío al chat general)
# ── XAUUSD (Gold) ─────────────────────────────────────────────────────────────
# News     → news_monitor (noticias económicas)
# Swing    → detectores Gold 1D + 4H
# Intraday → detectores Gold 1H
# Scalping → detectores Gold 15M + 5M
THREAD_ID_NEWS=878
THREAD_ID_SWING=539
THREAD_ID_INTRADAY=537
THREAD_ID_SCALPING=535
# ── EUR/USD ───────────────────────────────────────────────────────────────────
# Swing    → detector EURUSD 4H
# Intraday → detector EURUSD 1H
# Scalping → detectores EURUSD 15M + 5M
# (Si no tienes tópicos separados para EUR/USD, pon el mismo valor que Gold)
THREAD_ID_EURUSD_SWING=
THREAD_ID_EURUSD_INTRADAY=
THREAD_ID_EURUSD_SCALPING=

# Configuración de Base de Datos Turso (SQLite Cloud)
# Obtén estos valores en: https://turso.tech/
TURSO_DATABASE_URL=libsql://tu-database-url.turso.io
TURSO_AUTH_TOKEN=tu_token_de_autenticacion_turso

# ─────────────────────────────────────────────────────────────
# FUENTES DE DATOS — APIs opcionales para tiempo real
# ─────────────────────────────────────────────────────────────
# Twelve Data (GRATUITO — 800 req/día, sin tarjeta)
# Registro: https://twelvedata.com/apikey
# Necesario para datos en tiempo real en detectores 5M y 15M
TWELVE_DATA_API_KEY=tu_clave_twelve_data_aqui
TWELVE_DATA_API_KEY_2=tu_clave_twelve_data_cuenta2_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_3=tu_clave_twelve_data_cuenta3_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_4=tu_clave_twelve_data_cuenta4_aqui  # opcional, backup automático (800 req/día extra)
TWELVE_DATA_API_KEY_5=tu_clave_twelve_data_cuenta5_aqui  # opcional, backup automático (800 req/día extra)

# ─────────────────────────────────────────────────────────────
# ALERTAS POR EMAIL — fallos de detectores
# ─────────────────────────────────────────────────────────────
# Servidor SMTP desde el que se envían los emails de alerta
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Cuenta de Gmail que envía el correo (requiere "Contraseña de aplicación" si tienes 2FA)
SMTP_USER=
SMTP_PASSWORD=
# Destinatario de los emails de alerta (por defecto yesod3d@gmail.com)
ALERT_EMAIL=
DIRECT_FETCH_MODE=true

# ── Auto-cierre de señales activas ante eventos macro ─────────────────────────
# Opciones:
#   none         → nunca cerrar automáticamente (por defecto)
#   fomc         → cerrar solo en FOMC / Discurso Powell
#   high_impact  → cerrar en cualquier evento crítico (FOMC, NFP, CPI, PIB, PCE)
#   all          → cerrar en cualquier evento del calendario
AUTO_CLOSE_ON_EVENTS=none
