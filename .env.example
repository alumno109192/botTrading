# Configuración del Bot de Telegram
TELEGRAM_TOKEN=tu_token_del_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
# IDs de tópicos del foro (0 = sin tópico, envío al chat general)
# Swing    → detectores 1D + 4H
# Intraday → detectores 1H
# Scalping  → detectores 15M + 5M
THREAD_ID_SWING=304
THREAD_ID_INTRADAY=303
THREAD_ID_SCALPING=302

# Configuración de Base de Datos Turso (SQLite Cloud)
# Obtén estos valores en: https://turso.tech/
TURSO_DATABASE_URL=libsql://tu-database-url.turso.io
TURSO_AUTH_TOKEN=tu_token_de_autenticacion_turso
