# Configuración del Bot de Telegram
TELEGRAM_TOKEN=tu_token_del_bot_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui
# IDs de tópicos del foro (0 = sin tópico, envío al chat general)
# Swing    → detectores 1D + 4H
# Intraday → detectores 1H
# Scalping  → detectores 15M + 5M
THREAD_ID_SWING=304
THREAD_ID_INTRADAY=303
THREAD_ID_SCALPING=302

# Configuración de Base de Datos Turso (SQLite Cloud)
# Obtén estos valores en: https://turso.tech/
TURSO_DATABASE_URL=libsql://tu-database-url.turso.io
TURSO_AUTH_TOKEN=tu_token_de_autenticacion_turso

# ─────────────────────────────────────────────────────────────
# ZONAS S/R DE XAUUSD — editables desde Render dashboard
# (sin redeploy: cambiar en Render → env vars → Save → Render
#  reinicia en ~30 segundos con las nuevas zonas)
# Si no se definen, se usan los valores hardcodeados como fallback.
# ─────────────────────────────────────────────────────────────

# Detector 1D (Swing)
GOLD_1D_RESIST_HIGH=4980
GOLD_1D_RESIST_LOW=4900
GOLD_1D_SOPORTE_HIGH=4760
GOLD_1D_SOPORTE_LOW=4650

# Detector 4H (Swing)
GOLD_4H_RESIST_HIGH=4940
GOLD_4H_RESIST_LOW=4870
GOLD_4H_SOPORTE_HIGH=4780
GOLD_4H_SOPORTE_LOW=4700

# Detector 1H (Intraday)
GOLD_1H_RESIST_HIGH=4920
GOLD_1H_RESIST_LOW=4880
GOLD_1H_SOPORTE_HIGH=4790
GOLD_1H_SOPORTE_LOW=4750

# Detector 15M (Scalping)
GOLD_15M_RESIST_HIGH=4910
GOLD_15M_RESIST_LOW=4880
GOLD_15M_SOPORTE_HIGH=4790
GOLD_15M_SOPORTE_LOW=4760

# ─────────────────────────────────────────────────────────────
# FUENTES DE DATOS — APIs opcionales para tiempo real
# ─────────────────────────────────────────────────────────────
# Twelve Data (GRATUITO — 800 req/día, sin tarjeta)
# Registro: https://twelvedata.com/apikey
# Necesario para datos en tiempo real en detectores 5M y 15M
TWELVE_DATA_API_KEY=tu_clave_twelve_data_aqui
