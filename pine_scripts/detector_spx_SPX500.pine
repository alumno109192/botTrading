// ALERTCONDITIONS (para crear alertas desde panel TV)
// ══════════════════════════════════════
alertcondition(senal_sell_maxima and not cancelar_sell,                                   "⚡ SELL MÁXIMA",   "⚡ SELL MÁXIMA — SPX500")
alertcondition(senal_sell_fuerte and not senal_sell_maxima and not cancelar_sell,          "🔴 SELL FUERTE",  "🔴 SELL FUERTE — SPX500")
alertcondition(senal_sell_media  and not senal_sell_fuerte and not cancelar_sell,          "⚠️ SELL MEDIA",   "⚠️ SELL MEDIA — SPX500")
alertcondition(senal_sell_alerta and not senal_sell_media  and not cancelar_sell,          "👀 SELL ALERTA",  "👀 SELL ALERTA — SPX500")
alertcondition(senal_buy_maxima  and not cancelar_buy,                                    "⚡ BUY MÁXIMA",    "⚡ BUY MÁXIMA — SPX500")
alertcondition(senal_buy_fuerte  and not senal_buy_maxima  and not cancelar_buy,           "🟢 BUY FUERTE",   "🟢 BUY FUERTE — SPX500")
alertcondition(senal_buy_media   and not senal_buy_fuerte  and not cancelar_buy,           "⚠️ BUY MEDIA",    "⚠️ BUY MEDIA — SPX500")
alertcondition(senal_buy_alerta  and not senal_buy_media   and not cancelar_buy,           "👀 BUY ALERTA",   "👀 BUY ALERTA — SPX500")
alertcondition(aprox_resist and not en_zona_resist and not cancelar_sell,                  "🔔 PREP SELL",    "🔔 PREPARAR SELL LIMIT — SPX500")
alertcondition(aprox_soport and not en_zona_soporte and not cancelar_buy,                  "🔔 PREP BUY",     "🔔 PREPARAR BUY LIMIT — SPX500")
alertcondition(cancelar_sell,                                                              "❌ CANCEL SELL",  "❌ CANCELAR SELL LIMIT — SPX500")
alertcondition(cancelar_buy,                                                               "❌ CANCEL BUY",   "❌ CANCELAR BUY LIMIT — SPX500")
